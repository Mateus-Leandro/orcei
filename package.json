{
  "name": "orcei",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "types:db": "supabase gen types typescript --project-id fjlaysrwonssquljnztn --schema public > src/app/core/types/database.types.ts",
    "supabase:deploy-migrations": "supabase db push",
    "supabase:deploy-function": "bash -c 'read -p \"Nome da função Supabase: \" FN && supabase functions deploy \"$FN\"'"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.2.8",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@supabase/supabase-js": "^2.105.1",
    "ngx-mask": "^21.0.1",
    "rxjs": "~7.8.0",
    "supabase": "^2.95.6",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
